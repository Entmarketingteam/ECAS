      "position": [1560, 280]
    },
    {
      "parameters": {
        "jsCode": "// Merge Proxycurl enrichment back onto the contact\nconst contact = $('Flatten Apollo Results').first().json;\nconst proxycurl = $input.first().json;\n\nreturn [{\n  json: {\n    ...contact,\n    // Overwrite/supplement with Proxycurl data where available\n    headline: proxycurl?.headline || '',\n    summary: proxycurl?.summary || '',\n    follower_count: proxycurl?.follower_count || null,\n    connections: proxycurl?.connections || null,\n    profile_pic_url: proxycurl?.profile_pic_url || '',\n  }\n}];"
      },
