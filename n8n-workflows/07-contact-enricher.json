    {
      "parameters": {
        "jsCode": "// Derive likely domain from company name\n// e.g. \"Dominion Energy\" -> dominionenergy.com\nconst fields = $input.first().json.fields;\nconst projectRecordId = $input.first().json.id;\n\nfunction companyToDomain(name) {\n  if (!name) return null;\n  // Strip common suffixes\n  const cleaned = name\n    .toLowerCase()\n    .replace(/\\b(inc|llc|ltd|corp|corporation|company|co|group|holdings|international|partners|services|solutions|energy|power|electric|utilities|utility)\\b/g, '')\n    .replace(/[^a-z0-9]/g, '')\n    .trim();\n  return cleaned ? `${cleaned}.com` : null;\n}\n\nconst ownerCompany = fields.owner_company || '';\nconst epcCompany = fields.epc_company || '';\n\nconst companies = [];\nif (ownerCompany) {\n  companies.push({\n    name: ownerCompany,\n    domain: companyToDomain(ownerCompany),\n    role: 'owner',\n  });\n}\nif (epcCompany && epcCompany !== ownerCompany) {\n  companies.push({\n    name: epcCompany,\n    domain: companyToDomain(epcCompany),\n    role: 'epc',\n  });\n}\n\nreturn companies.map(c => ({\n  json: {\n    ...c,\n    project_record_id: projectRecordId,\n    project_name: fields.project_name || '',\n    project_state: fields.state || '',\n  }\n}));"
      },
      "id": "code-derive-domains",
      "name": "Derive Company Domains",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.apollo.io/api/v1/people/search",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "api_key",
              "value": "={{ $env.APOLLO_API_KEY }}"
            },
            {
              "name": "titles",
              "value": "=[\"Director of Preconstruction\", \"VP Operations\", \"Project Executive\", \"Estimating Manager\", \"Director of Business Development\", \"VP Business Development\"]"
            },
            {
              "name": "organization_domains",
              "value": "={{ [$json.domain].filter(Boolean) }}"
            },
            {
              "name": "page",
              "value": 1
            },
            {
              "name": "per_page",
              "value": 10
            }
          ]
        },
        "options": {
          "timeout": 30000
        }
      },
      "id": "http-apollo",
      "name": "Apollo: Search People",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 400]
    },
    {
      "parameters": {
        "jsCode": "// Flatten Apollo results and attach parent context\nconst apolloResp = $input.first().json;\nconst companyCtx = $('Derive Company Domains').first().json;\n\nconst people = apolloResp?.people || apolloResp?.contacts || [];\n\nconst withEmail = people.filter(p => p.email && p.email !== 'email_not_unlocked@domain.com');\n\nconsole.log(`Apollo returned ${people.length} people, ${withEmail.length} with email`);\n\nreturn withEmail.map(p => ({\n  json: {\n    // Apollo fields\n    first_name: p.first_name || '',\n    last_name: p.last_name || '',\n    email: p.email || '',\n    title: p.title || '',\n    company_name: p.organization_name || companyCtx.name,\n    linkedin_url: p.linkedin_url || '',\n    city: p.city || '',\n    state: p.state || '',\n    phone: p.phone_numbers?.[0]?.raw_number || '',\n    // Context from parent nodes\n    company_role: companyCtx.role,\n    company_domain: companyCtx.domain,\n    project_record_id: companyCtx.project_record_id,\n    project_name: companyCtx.project_name,\n    project_state: companyCtx.project_state,\n    apollo_id: p.id || '',\n  }\n}));"
      },
      "id": "code-flatten-apollo",
      "name": "Flatten Apollo Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 400]
    },
